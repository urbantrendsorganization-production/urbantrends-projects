# OnboardKit — environment configuration
#
# Copy to `ops/.env` for the docker-compose dev stack, or to `backend/.env` for
# running the API/worker natively with `cargo run`. Secrets committed here are
# PLACEHOLDERS ONLY (CLAUDE.md §3). Never commit real credentials.
#
# Each variable is tagged with the phase that first consumes it.

# ─── Application ────────────────────────────────────────────────────────────
# development | production. Controls log format (pretty vs JSON). [Phase 0]
APP_ENV=development

# ─── API server ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0                 # [Phase 0]
API_PORT=8080                    # [Phase 0]

# ─── Database (Postgres) ────────────────────────────────────────────────────
# When running natively, host is localhost. Inside compose, host is `postgres`.
DATABASE_URL=postgres://onboardkit:onboardkit@localhost:5432/onboardkit  # [Phase 0]
DB_MAX_CONNECTIONS=10            # [Phase 0]
# Credentials used by the compose `postgres` service and to build DATABASE_URL.
POSTGRES_USER=onboardkit         # [Phase 0]
POSTGRES_PASSWORD=onboardkit     # [Phase 0] placeholder — change for anything real
POSTGRES_DB=onboardkit           # [Phase 0]

# ─── JWT / auth ─────────────────────────────────────────────────────────────
# MUST be >= 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=dev-insecure-secret-change-me-at-least-32-chars   # [Phase 0]
JWT_ACCESS_TTL_SECS=900          # 15 minutes  [Phase 0]
JWT_REFRESH_TTL_SECS=1209600     # 14 days     [Phase 0]

# ─── Logging ────────────────────────────────────────────────────────────────
# tracing EnvFilter directive. Falls back to a sane default when unset.
RUST_LOG=info,sqlx=warn,tower_http=info   # [Phase 0]

# ─── Background worker ──────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_SECS=5      # [Phase 0]

# ─── Object storage (S3 / MinIO) ────────────────────────────────────────────
# Dev uses the compose `minio` service; prod uses Hetzner Object Storage. [Phase 2]
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=onboardkit
S3_ACCESS_KEY_ID=onboardkit
S3_SECRET_ACCESS_KEY=onboardkit-secret       # placeholder
S3_FORCE_PATH_STYLE=true
# Credentials for the compose `minio` service (mirror the S3_* keys above).
MINIO_ROOT_USER=onboardkit
MINIO_ROOT_PASSWORD=onboardkit-secret        # placeholder

# ─── OTP service ────────────────────────────────────────────────────────────
# Dev-only: expose OTP codes to a dev table for testing. MUST default off. [Phase 1/2]
DEV_EXPOSE_OTP=false

# ─── SMS providers ──────────────────────────────────────────────────────────
# Africa's Talking (primary) and Infobip (fallback). Placeholders only. [Phase 3]
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=
INFOBIP_BASE_URL=
INFOBIP_API_KEY=
INFOBIP_SENDER_ID=
